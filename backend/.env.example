# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/ai-notebook

# Groq (LLM) — get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Recommended: llama-3.3-70b-versatile (quality) or llama-3.1-8b-instant (speed)
# Other options: openai/gpt-oss-120b, openai/gpt-oss-20b, qwen/qwen3-32b
GROQ_MODEL=llama-3.3-70b-versatile

# HuggingFace Inference API (embeddings) — get a free token at https://huggingface.co/settings/tokens
# A "read" token is sufficient. Free tier is generous; first call to a cold model may take ~20s.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Strong general-purpose model, 384 dims, fast, MTEB-leading for its size
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# Retrieval tuning
TOP_K=6
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# ElevenLabs TTS (OPTIONAL — leave blank to use only free browser TTS)
# Get a free key at https://elevenlabs.io/app/settings/api-keys
# Free tier: 10,000 characters/month, ~10 mins of audio
ELEVENLABS_API_KEY=
# Default voice (Rachel — free tier friendly). Browse more at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# eleven_flash_v2_5 = ~75ms latency, cheapest chars; eleven_multilingual_v2 = best quality
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
